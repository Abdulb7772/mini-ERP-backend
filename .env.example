# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGODB_URI=your_mongodb_connection_string

# JWT Secret
JWT_SECRET=your_jwt_secret_key

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
# Optional backward-compatible alias (if you already use this key)
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_CONNECTION_TIMEOUT=10000
EMAIL_GREETING_TIMEOUT=10000
EMAIL_SOCKET_TIMEOUT=15000
EMAIL_DNS_TIMEOUT=10000

# Frontend URLs (for CORS)
CLIENT_URL=https://your-client-side.vercel.app
ADMIN_URL=https://your-admin-side.vercel.app

# Stripe (if using payment)
STRIPE_SECRET_KEY=your_stripe_secret_key

# Cloudinary (if using image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
